# Canvas personal access token (for local dev/testing only, bypasses OAuth flow)
CANVAS_TEST_TOKEN=your_canvas_personal_access_token

# Canvas API base URL (used by MCP tools to query courses, grades, etc.)
CANVAS_BASE_URL=https://fhict.instructure.com

# Fontys OIDC — used for student authentication (identity.fhict.nl)
# Temporary until Canvas Developer Key is issued; then these are replaced by CANVAS_CLIENT_* vars
FONTYS_ISSUER_URL=https://identity.fhict.nl
FONTYS_CLIENT_ID=your_fontys_client_id
FONTYS_CLIENT_SECRET=your_fontys_client_secret
FONTYS_REDIRECT_URI=http://localhost:3000/auth/canvas/callback

# Canvas Developer Key — uncomment and populate when Fontys issues the key
# CANVAS_CLIENT_ID=your_canvas_client_id
# CANVAS_CLIENT_SECRET=your_canvas_client_secret

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Token encryption — generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=your_64_char_hex_key

# Session config
SESSION_INACTIVITY_DAYS=30

# Server
PORT=3000
NODE_ENV=development

# Optional: expose MCP server on this port for external MCP clients
# MCP_PORT=3001
